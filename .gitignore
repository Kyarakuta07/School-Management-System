# CI4 writable directory (logs, cache, sessions, uploads)
moe/writable/**
!moe/writable/.htaccess
!moe/writable/index.html

# CI4 vendor (installed via composer)
moe/vendor/

# Large asset source files (originals before rename)
PET MOE/

# Backup copies
moe_backup/